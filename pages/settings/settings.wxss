/* settings.wxss */
.container {
  min-height: 100vh;
  padding: 32rpx;
}

.setting-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}

.setting-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.price-header {
  display: flex;
  align-items: center;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.price-header-label {
  width: 120rpx;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  color: #64748B;
}

.price-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F1F5F9;
}

.price-row:last-child {
  border-bottom: none;
}

.price-input-small {
  width: 120rpx;
  height: 72rpx;
  text-align: center;
  background-color: #F8FAFC;
  border: 1rpx solid #E2E8F0;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.renew-badge {
  font-size: 24rpx;
  font-weight: 700;
  color: #2563EB;
  background-color: #EFF6FF;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.picker-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  background-color: #F8FAFC;
}

/* User List Styles */
.user-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.user-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F1F5F9;
}

.user-item:last-child {
  border-bottom: none;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.user-phone {
  font-size: 24rpx;
  color: #64748B;
}

.user-actions {
  display: flex;
  gap: 24rpx;
}

.edit-btn, .delete-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.empty-users {
  text-align: center;
  padding: 40rpx;
  color: #94A3B8;
}

/* Modal Styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-container {
  width: 80%;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.close-btn {
  font-size: 32rpx;
  color: #94A3B8;
  padding: 8rpx;
}

.modal-body {
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
