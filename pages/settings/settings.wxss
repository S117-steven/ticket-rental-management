/* settings.wxss */
.container {
  min-height: 100vh;
  padding: 32rpx;
}

.setting-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}

.setting-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.price-header {
  display: flex;
  align-items: center;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.price-header-label {
  width: 120rpx;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  color: #64748B;
}

.price-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F1F5F9;
}

.price-row:last-child {
  border-bottom: none;
}

.price-input-small {
  width: 120rpx;
  height: 72rpx;
  text-align: center;
  background-color: #F8FAFC;
  border: 1rpx solid #E2E8F0;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.renew-badge {
  font-size: 24rpx;
  font-weight: 700;
  color: #2563EB;
  background-color: #EFF6FF;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.picker-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  background-color: #F8FAFC;
}
