<view class="container">
    <view class="text-xl font-bold mb-6">{{t.set_title}}</view>

    <view class="setting-card">
        <view class="setting-title">
            <text>🌐</text> {{t.set_lang}}
        </view>
        <picker mode="selector" range="{{['简体中文', 'English', 'Svenska']}}" bindchange="onLangChange">
            <view class="picker-selector" hover-class="hover-effect">
                <text>{{config.language === 'zh' ? '简体中文' : (config.language === 'en' ? 'English' : 'Svenska')}}</text>
                <text class="text-sm">></text>
            </view>
        </picker>
    </view>

    <view class="setting-card">
        <view class="flex justify-between items-start mb-4">
            <view class="setting-title mb-0">
                <text>🔄</text> {{t.set_cycle}}
            </view>
            <view class="renew-badge" bindtap="renewTicket" hover-class="hover-effect">
                {{t.set_renew}}
            </view>
        </view>
        <view class="flex flex-col gap-2">
            <text class="text-sm font-medium">{{t.set_date}}</text>
            <picker mode="date" value="{{isoDate}}" bindchange="onDateChange">
                <view class="input" hover-class="hover-effect">{{isoDate}}</view>
            </picker>
            <text class="text-xs">{{t.set_date_hint}}</text>
        </view>
    </view>

    <view class="setting-card">
        <view class="setting-title mb-4">{{t.set_price}}</view>
        <view class="price-table">
            <view class="price-header">
                <view class="flex-1 text-xs font-bold">{{t.ob_th_dur}}</view>
                <view class="price-header-label">{{t.ob_th_new}}</view>
                <view style="width: 16rpx;"></view>
                <view class="price-header-label">{{t.ob_th_reg}}</view>
            </view>
            <block wx:for="{{DurationType}}" wx:key="*this">
                <view class="price-row">
                    <view class="flex-1 text-sm font-medium">{{durationLabels[index]}}</view>
                    <input class="price-input-small" type="number" min="0" max="9999"
                           value="{{config.priceMatrix.newCustomer[item]}}" bindblur="updatePrice" data-type="newCustomer" data-dur="{{item}}" />
                    <view style="width: 16rpx;"></view>
                    <input class="price-input-small" type="number" min="0" max="9999"
                           value="{{config.priceMatrix.regularCustomer[item]}}" bindblur="updatePrice" data-type="regularCustomer" data-dur="{{item}}" />
                </view>
            </block>
        </view>
    </view>

    <view class="setting-card">
        <view class="setting-title mb-4">{{t.set_export}}</view>
        <view class="flex gap-4">
            <button class="btn btn-secondary flex-1" bindtap="exportData" hover-class="hover-effect">{{t.set_export}}</button>
            <button class="btn btn-secondary flex-1" bindtap="importData" hover-class="hover-effect">{{t.set_import}}</button>
        </view>
    </view>

    <view class="setting-card">
        <view class="setting-title mb-4">👥 {{t.set_users_title}}</view>
        <view class="user-list">
            <view wx:for="{{users}}" wx:key="id" class="user-item">
                <view class="user-info">
                    <text class="user-name">{{item.name}}</text>
                    <text class="user-phone">{{item.phone}}</text>
                </view>
                <view class="user-actions">
                    <text class="edit-btn" bindtap="editUser" data-id="{{item.id}}">✏️</text>
                    <text class="delete-btn" bindtap="deleteUser" data-id="{{item.id}}">🗑️</text>
                </view>
            </view>
            <view wx:if="{{users.length === 0}}" class="empty-users">
                <text>{{t.set_no_users}}</text>
            </view>
        </view>
    </view>

    <view class="text-center py-6">
        <text class="text-xs">{{t.set_feedback}}</text>
    </view>
</view>

<!-- Edit User Modal -->
<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="cancelEditUser">
    <view class="modal-container" catchtap="noop">
        <view class="modal-header">
            <text class="text-lg">{{t.set_edit_user}}</text>
            <view class="close-btn" bindtap="cancelEditUser">x</view>
        </view>
        <view class="modal-body">
            <view class="form-group">
                <text class="form-label">{{t.set_user_name}}</text>
                <input class="form-input" value="{{editingUser.name}}" bindinput="onUserNameInput" placeholder="{{t.set_user_name}}" />
            </view>
            <view class="form-group">
                <text class="form-label">{{t.set_user_phone}}</text>
                <input class="form-input" value="{{editingUser.phone}}" bindinput="onUserPhoneInput" placeholder="{{t.set_user_phone}}" type="number" />
            </view>
        </view>
        <view class="modal-footer">
            <button class="btn btn-secondary" bindtap="cancelEditUser">{{t.ord_cancel}}</button>
            <button class="btn btn-primary" bindtap="saveUser">{{t.set_save_user}}</button>
        </view>
    </view>
</view>
