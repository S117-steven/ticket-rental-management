/* Dashboard specific styles */
.fixed { position: fixed; }
.bottom-10 { bottom: 80rpx; } /* adjusted for tabbar */
.right-5 { right: 40rpx; }
.z-10 { z-index: 10; }
.rounded-full { border-radius: 9999rpx; }

/* Scroll View for Recent Activity */
.recent-scroll-view {
  max-height: 600rpx; /* Approximately 4.5 items */
}

/* Modal Styles */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-active {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 85%;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  transform: translateY(100rpx);
  transition: all 0.3s;
}

.modal-active .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.close-btn {
  font-size: 48rpx;
  color: #94A3B8;
  padding: 8rpx;
}

.modal-body-scroll {
  max-height: 60vh;
}

.user-detail-card {
  border-color: #F1F5F9;
  background-color: #F8FAFC;
}

.last-border-0:last-child {
  border-bottom: 0;
}

/* Ticket Switcher */
.ticket-tabs {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding: 8rpx 0;
}

.ticket-tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background-color: #F1F5F9;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  white-space: nowrap;
  border: 2rpx solid transparent;
}

.ticket-tab-active {
  background-color: #EFF6FF;
  color: #2563EB;
  border-color: #93C5FD;
}

.summer-badge {
  font-size: 24rpx;
}

.monthly-badge {
  font-size: 24rpx;
}

.ticket-info-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  color: #ffffff;
}

.ticket-type-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.ticket-type-badge.summer {
  background-color: rgba(255, 255, 255, 0.2);
}

.ticket-type-badge.monthly {
  background-color: rgba(255, 255, 255, 0.2);
}

.ticket-tabs.switching {
  opacity: 0.5;
  transition: opacity 0.2s;
}

.single-ticket-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background-color: #F8FAFC;
  border-radius: 12rpx;
}

.revenue-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background-color: #F8FAFC;
  border-radius: 12rpx;
}

/* Summer Ticket Cost Card */
.summer-cost-card {
  background-color: #FFFBEB;
  border: 2rpx solid #FDE68A;
  border-radius: 16rpx;
  padding: 24rpx;
}

/* Search Styles */
.search-bar {
  background-color: #F8FAFC;
  border-radius: 16rpx;
  padding: 16rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 0 16rpx;
  margin-bottom: 16rpx;
}

.search-icon {
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.clear-btn {
  color: #94A3B8;
  padding: 8rpx;
}

.filter-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-tag {
  padding: 8rpx 16rpx;
  background-color: #E2E8F0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #64748B;
}

.filter-tag.active {
  background-color: #2563EB;
  color: #ffffff;
}
